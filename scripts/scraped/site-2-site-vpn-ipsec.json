  "html": "<div class=\"row-fluid-wrapper\">\n<div class=\"row-fluid\">\n<div class=\"span12 widget-span widget-type-cell \" style=\"\" data-widget-type=\"cell\" data-x=\"0\" data-w=\"12\">\n\n<div class=\"row-fluid-wrapper row-depth-1 row-number-1 dnd-section kb-article-row-0-padding\">\n<div class=\"row-fluid \">\n<div class=\"span12 widget-span widget-type-cell dnd-column\" style=\"\" data-widget-type=\"cell\" data-x=\"0\" data-w=\"12\">\n\n<div class=\"row-fluid-wrapper row-depth-1 row-number-2 dnd-row\">\n<div class=\"row-fluid \">\n<div class=\"span12 widget-span widget-type-custom_widget dnd-module\" style=\"\" data-widget-type=\"custom_widget\" data-x=\"0\" data-w=\"12\">\n<div id=\"hs_cos_wrapper_kb-article-module-2\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_module\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"module\">\n\n</div>\n\n</div><!--end widget-span -->\n</div><!--end row-->\n</div><!--end row-wrapper -->\n\n<div class=\"row-fluid-wrapper row-depth-1 row-number-3 dnd-row\">\n<div class=\"row-fluid \">\n<div class=\"span12 widget-span widget-type-custom_widget dnd-module\" style=\"\" data-widget-type=\"custom_widget\" data-x=\"0\" data-w=\"12\">\n<div id=\"hs_cos_wrapper_kb-article-module-3\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_module\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"module\">\n  <h1 id=\"hs_cos_wrapper_kb-article-module-3_\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_inline_text_field\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"inline_text_field\">Site 2 Site VPN - IPSEC (require subscription)</h1>\n</div>\n\n</div><!--end widget-span -->\n</div><!--end row-->\n</div><!--end row-wrapper -->\n\n<div class=\"row-fluid-wrapper row-depth-1 row-number-4 dnd-row\">\n<div class=\"row-fluid \">\n<div class=\"span12 widget-span widget-type-custom_widget dnd-module\" style=\"\" data-widget-type=\"custom_widget\" data-x=\"0\" data-w=\"12\">\n<div id=\"hs_cos_wrapper_kb-article-module-4\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_module\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"module\">\n  <h2 id=\"hs_cos_wrapper_kb-article-module-4_\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_inline_text_field\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"inline_text_field\">If you have more than 3 on-premise data sources, we offer Site2Site VPN.</h2>\n</div>\n\n</div><!--end widget-span -->\n</div><!--end row-->\n</div><!--end row-wrapper -->\n\n<div class=\"row-fluid-wrapper row-depth-1 row-number-5 dnd-row\">\n<div class=\"row-fluid \">\n<div class=\"span12 widget-span widget-type-custom_widget dnd-module\" style=\"\" data-widget-type=\"custom_widget\" data-x=\"0\" data-w=\"12\">\n<div id=\"hs_cos_wrapper_kb-article-module-5\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_module\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"module\">\n  <div id=\"hs_cos_wrapper_kb-article-module-5_\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_inline_richtext_field\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"inline_richtext_field\"><p>* Note that Site 2 Site VPN requires a Site 2 Site subscription 0r a Custom Security Framework subscription</p>\n<h3>What information do we need to establish Site2Site</h3>\n<p><span style=\"font-size: 1rem;\">The requirement to establish a connection is that the hardware or software that the customer is using supports IPSEC connection with the latest standards.<br><br>Information needed to establish connection:</span></p>\n<ol>\n<li><span style=\"font-size: 1rem;\">Peering IP (public IP on the customer side that is needed to establish the connection)</span></li>\n<li><span style=\"font-size: 1rem;\">Private IPs and/or subnets of the devices that need to be scanned</span></li>\n<li><span style=\"font-size: 1rem;\">Phone number to share PSK (Pre-shared key)</span></li>\n<li><span style=\"font-size: 1rem;\">Certificate if the customer is using that as an authentication method.</span><br><span style=\"font-size: 1rem;\"></span></li>\n</ol>\n<p><span style=\"font-size: 1rem;\">Send the information to support@dataandmore.com, and we will get you up and running.</span></p>\n<p>&nbsp;</p>\n<p>&nbsp;</p></div>\n</div>\n\n</div><!--end widget-span -->\n</div><!--end row-->\n</div><!--end row-wrapper -->\n\n</div><!--end widget-span -->\n</div><!--end row-->\n</div><!--end row-wrapper -->\n\n</div><!--end widget-span -->\n</div>\n</div>",
  "sourceUrl": "https://support.dataandmore.com/en/knowledge/site-2-site-vpn-ipsec"
