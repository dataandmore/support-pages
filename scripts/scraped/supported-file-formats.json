  "html": "<div class=\"row-fluid-wrapper\">\n<div class=\"row-fluid\">\n<div class=\"span12 widget-span widget-type-cell \" style=\"\" data-widget-type=\"cell\" data-x=\"0\" data-w=\"12\">\n\n<div class=\"row-fluid-wrapper row-depth-1 row-number-1 dnd-section kb-article-row-0-padding\">\n<div class=\"row-fluid \">\n<div class=\"span12 widget-span widget-type-cell dnd-column\" style=\"\" data-widget-type=\"cell\" data-x=\"0\" data-w=\"12\">\n\n<div class=\"row-fluid-wrapper row-depth-1 row-number-2 dnd-row\">\n<div class=\"row-fluid \">\n<div class=\"span12 widget-span widget-type-custom_widget dnd-module\" style=\"\" data-widget-type=\"custom_widget\" data-x=\"0\" data-w=\"12\">\n<div id=\"hs_cos_wrapper_kb-article-module-2\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_module\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"module\">\n\n</div>\n\n</div><!--end widget-span -->\n</div><!--end row-->\n</div><!--end row-wrapper -->\n\n<div class=\"row-fluid-wrapper row-depth-1 row-number-3 dnd-row\">\n<div class=\"row-fluid \">\n<div class=\"span12 widget-span widget-type-custom_widget dnd-module\" style=\"\" data-widget-type=\"custom_widget\" data-x=\"0\" data-w=\"12\">\n<div id=\"hs_cos_wrapper_kb-article-module-3\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_module\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"module\">\n  <h1 id=\"hs_cos_wrapper_kb-article-module-3_\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_inline_text_field\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"inline_text_field\">Supported file formats</h1>\n</div>\n\n</div><!--end widget-span -->\n</div><!--end row-->\n</div><!--end row-wrapper -->\n\n<div class=\"row-fluid-wrapper row-depth-1 row-number-4 dnd-row\">\n<div class=\"row-fluid \">\n<div class=\"span12 widget-span widget-type-custom_widget dnd-module\" style=\"\" data-widget-type=\"custom_widget\" data-x=\"0\" data-w=\"12\">\n<div id=\"hs_cos_wrapper_kb-article-module-4\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_module\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"module\">\n  <h2 id=\"hs_cos_wrapper_kb-article-module-4_\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_inline_text_field\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"inline_text_field\">Data More solution supports the following file formats</h2>\n</div>\n\n</div><!--end widget-span -->\n</div><!--end row-->\n</div><!--end row-wrapper -->\n\n<div class=\"row-fluid-wrapper row-depth-1 row-number-5 dnd-row\">\n<div class=\"row-fluid \">\n<div class=\"span12 widget-span widget-type-custom_widget dnd-module\" style=\"\" data-widget-type=\"custom_widget\" data-x=\"0\" data-w=\"12\">\n<div id=\"hs_cos_wrapper_kb-article-module-5\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_module\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"module\">\n  <div id=\"hs_cos_wrapper_kb-article-module-5_\" class=\"hs_cos_wrapper hs_cos_wrapper_widget hs_cos_wrapper_type_inline_richtext_field\" style=\"\" data-hs-cos-general-type=\"widget\" data-hs-cos-type=\"inline_richtext_field\"><p>We use Apache Tika as the initial file ingestion process, see the list of supported file formats: https://tika.apache.org/1.10/formats.html</p>\n<p>We analyse text files and all images. Currently, we do not analyse the content of video formats, but it is possible to use an additional third party tool if this is a requirement.</p></div>\n</div>\n\n</div><!--end widget-span -->\n</div><!--end row-->\n</div><!--end row-wrapper -->\n\n</div><!--end widget-span -->\n</div><!--end row-->\n</div><!--end row-wrapper -->\n\n</div><!--end widget-span -->\n</div>\n</div>",
  "sourceUrl": "https://support.dataandmore.com/en/knowledge/supported-file-formats"
}