# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (matches docker-compose.yml)
DATABASE_URL=postgresql://support_user:password@localhost:5432/support_portal

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email (Postmark) ─────────────────────────────────────────────────────────
POSTMARK_API_KEY=your-postmark-server-token
POSTMARK_FROM_EMAIL=support@dataandmore.com

# ─── Docker Compose (production only) ────────────────────────────────────────
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=your-db-password
